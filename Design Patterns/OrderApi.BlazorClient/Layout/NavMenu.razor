@* [Pattern: Chain of Responsibility][SRP] Role-aware navigation using AuthorizeView to control which links appear. *@
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView Context="navAuthState">
    <Authorized>
        <MudNavLink Href="@AppRoutes.MyOrders" Icon="@Icons.Material.Filled.ShoppingCart" IconColor="Color.Inherit">
            My Orders
        </MudNavLink>

        <AuthorizeView Roles="Admin" Context="adminAuthState">
            <MudNavLink Href="@AppRoutes.AllOrders" Icon="@Icons.Material.Filled.ManageSearch" IconColor="Color.Inherit">
                All Orders (Admin)
            </MudNavLink>
        </AuthorizeView>

        <MudNavLink Href="@AppRoutes.PlaceOrder" Icon="@Icons.Material.Filled.AddCircle" IconColor="Color.Inherit">
            Place Order
        </MudNavLink>

        <MudDivider Class="my-2" />

        <MudNavLink Href="@AppRoutes.Login" Icon="@Icons.Material.Filled.ExitToApp" IconColor="Color.Inherit">
            Logout
        </MudNavLink>
    </Authorized>
    <NotAuthorized>
        <MudNavLink Href="@AppRoutes.Login" Icon="@Icons.Material.Filled.Login" IconColor="Color.Inherit">
            Login
        </MudNavLink>
    </NotAuthorized>
</AuthorizeView>
