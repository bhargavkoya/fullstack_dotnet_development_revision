<MudTr>
    <MudTd DataLabel="Product">@Item.ProductName</MudTd>
    <MudTd DataLabel="Qty">@Item.Quantity</MudTd>
    <MudTd DataLabel="Unit Price">@Item.UnitPrice.ToString("C")</MudTd>
    <MudTd DataLabel="Line Total">@Item.LineTotal.ToString("C")</MudTd>
</MudTr>

@code
{
    [Parameter]
    public OrderItemResponse Item { get; set; } = default!;
}
