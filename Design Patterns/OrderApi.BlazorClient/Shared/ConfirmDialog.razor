@inject MudBlazor.IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
        <MudText Typo="Typo.body2">@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Disabled="@_isExecuting" OnClick="CancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" Disabled="@_isExecuting" OnClick="ConfirmAsync">
            @if (_isExecuting)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
            }
            Confirm
        </MudButton>
    </DialogActions>
</MudDialog>

@code
{
    [CascadingParameter]
    private MudBlazor.MudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    private bool _isExecuting;

    private void CancelAsync() => MudDialog?.Cancel();

    private async Task ConfirmAsync()
    {
        if (_isExecuting)
        {
            return;
        }

        _isExecuting = true;
        try
        {
            await OnConfirm.InvokeAsync();
            MudDialog?.Close();
        }
        finally
        {
            _isExecuting = false;
        }
    }
}
