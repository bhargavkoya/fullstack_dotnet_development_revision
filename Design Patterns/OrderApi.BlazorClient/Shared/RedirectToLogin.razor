@* [Pattern: Chain of Responsibility] Unauthenticated users are caught at the router level and redirected here. *@
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@code
{
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(AppRoutes.Unauthorized, forceLoad: false);
            return;
        }

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrEmpty(relativePath) ? "/" : $"/{relativePath}";
        Navigation.NavigateTo($"{AppRoutes.Login}?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
    }
}
