<MudCard Elevation="1">
    <MudCardContent>
        <MudStack Spacing="4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
                <MudText Typo="Typo.h6">Order Items</MudText>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Filled">
                    @Items.Count item(s)
                </MudChip>
            </MudStack>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                Customer discount is fixed to <strong>@GetDiscountLabel(DiscountType)</strong>.
            </MudAlert>

            <MudStack Spacing="3">
                @for (var index = 0; index < Items.Count; index++)
                {
                    var item = Items[index];
                    var currentIndex = index;

                    <MudPaper @key="item.DraftId" Class="pa-4" Elevation="0" Outlined="true">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudSelect T="Guid"
                                           Label="Product"
                                           Variant="Variant.Outlined"
                                           Dense="true"
                                           Value="item.ProductId"
                                           ValueChanged="value => OnProductChanged(currentIndex, value)">
                                    @foreach (var product in Products)
                                    {
                                        <MudSelectItem Value="@product.ProductId">@product.ProductName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudNumericField T="int"
                                                 Label="Qty"
                                                 Variant="Variant.Outlined"
                                                 @bind-Value="item.Quantity"
                                                 Min="1"
                                                 Immediate="true" />
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudNumericField T="decimal"
                                                 Label="Unit Price"
                                                 Variant="Variant.Outlined"
                                                 Value="item.UnitPrice"
                                                 ReadOnly="true"
                                                 Min="0"
                                                 HideSpinButtons="true" />
                            </MudItem>
                            <MudItem xs="12" md="2" Class="d-flex align-center justify-end">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Disabled="@(Items.Count == 1)"
                                               OnClick="() => RemoveItemAsync(currentIndex)" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            </MudStack>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddItemAsync">
                    Add Item
                </MudButton>

                <MudStack AlignItems="AlignItems.End" Spacing="0">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Subtotal</MudText>
                    <MudText Typo="Typo.h6">@Subtotal.ToString("C")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Discount: @DiscountAmount.ToString("C")</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Total: @TotalAmount.ToString("C")</MudText>
                </MudStack>
            </MudStack>
        </MudStack>
    </MudCardContent>
</MudCard>

@code
{
    [Parameter]
    public List<PlaceOrderLineDraft> Items { get; set; } = [];

    [Parameter]
    public IReadOnlyList<ProductCatalogItemResponse> Products { get; set; } = [];

    [Parameter]
    public string DiscountType { get; set; } = "loyalty";

    [Parameter]
    public decimal Subtotal { get; set; }

    [Parameter]
    public decimal DiscountAmount { get; set; }

    [Parameter]
    public decimal TotalAmount { get; set; }

    private async Task AddItemAsync()
    {
        await InvokeAsync(() =>
        {
            var newItem = new PlaceOrderLineDraft();
            if (Products.Count > 0)
            {
                var defaultProduct = Products[0];
                newItem.ProductId = defaultProduct.ProductId;
                newItem.ProductName = defaultProduct.ProductName;
                newItem.UnitPrice = defaultProduct.UnitPrice;
            }

            Items.Add(newItem);
        });
    }

    private async Task RemoveItemAsync(int index)
    {
        if (Items.Count == 1)
        {
            return;
        }

        await InvokeAsync(() => Items.RemoveAt(index));
    }

    private Task OnProductChanged(int itemIndex, Guid productId)
    {
        if (itemIndex < 0 || itemIndex >= Items.Count)
        {
            return Task.CompletedTask;
        }

        var product = Products.FirstOrDefault(item => item.ProductId == productId);
        if (product is null)
        {
            return Task.CompletedTask;
        }

        var item = Items[itemIndex];
        item.ProductId = product.ProductId;
        item.ProductName = product.ProductName;
        item.UnitPrice = product.UnitPrice;

        return Task.CompletedTask;
    }

    private static string GetDiscountLabel(string discountType) => discountType.ToLowerInvariant() switch
    {
        "loyalty" => "Loyalty",
        "seasonal" => "Seasonal",
        _ => "None"
    };
}