{
  "JwtSettings": {
    "SecretKey": "dev-secret-key-for-testing-only-replace-in-production-min32chars",
    "Issuer": "OrderApi",
    "Audience": "OrderApiClients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "OAuthSettings": {
    "Google": {
      "ClientId": "your-google-client-id-dev",
      "ClientSecret": "your-google-client-secret-dev",
      "RedirectUri": "https://localhost:5001/api/auth/oauth/google/callback"
    },
    "GitHub": {
      "ClientId": "your-github-client-id-dev",
      "ClientSecret": "your-github-client-secret-dev",
      "RedirectUri": "https://localhost:5001/api/auth/oauth/github/callback"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Debug",
      "OrderApi": "Debug"
    }
  }
}
